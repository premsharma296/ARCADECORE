datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               String            @id // Matches Clerk ID
  email            String            @unique
  username         String            @unique
  avatarUrl        String?
  xp               Int               @default(0)
  coins            Int               @default(100)  // Spendable Coin Shop balance
  unlockedBorders  String            @default("none") // Comma-separated unlocked cosmetic IDs, e.g. "none,outrun-pink"
  equippedBorder   String            @default("none") // Currently active profile border ID
  level            Int               @default(1)
  isPremium        Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  comments         Comment[]
  ratings          Rating[]
  favorites        Favorite[]
  leaderboard      Leaderboard[]
  userAchievements UserAchievement[]
}

model Game {
  id             String        @id @default(uuid())
  title          String
  slug           String        @unique
  description    String
  instructions   String?
  controls       String?
  iframeUrl      String        // HTML5 source URL or embedded location
  thumbnailUrl   String
  bannerUrl      String?
  playCount      Int           @default(0)
  rating         Float         @default(0.0)
  developerId    String?
  developer      Developer?    @relation(fields: [developerId], references: [id])
  isFeatured     Boolean       @default(false)
  isSponsored    Boolean       @default(false)
  releaseDate    DateTime      @default(now())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  categories     Category[]    @relation("GameToCategory")
  tags           Tag[]         @relation("GameToTag")
  comments       Comment[]
  ratings        Rating[]
  favorites      Favorite[]
  leaderboard    Leaderboard[]
  gameViews      GameView[]
  screenshots    String[]      // Array of screenshot URLs
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  icon        String   // Lucide icon name
  games       Game[]   @relation("GameToCategory")
}

model Tag {
  id    String @id @default(uuid())
  name  String @unique
  slug  String @unique
  games Game[] @relation("GameToTag")
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  gameId    String
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Rating {
  id        String   @id @default(uuid())
  value     Int      // 1 to 5
  gameId    String
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([gameId, userId])
}

model Favorite {
  id        String   @id @default(uuid())
  gameId    String
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([gameId, userId])
}

model Leaderboard {
  id        String   @id @default(uuid())
  score     Int
  gameId    String
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Achievement {
  id          String   @id @default(uuid())
  title       String
  description String
  xpReward    Int
  iconUrl     String
  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(uuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  unlockedAt    DateTime    @default(now())

  @@unique([userId, achievementId])
}

model Developer {
  id        String   @id @default(uuid())
  name      String
  website   String?
  games     Game[]
}

model Advertisement {
  id          String   @id @default(uuid())
  zone        String   // "HEADER", "SIDEBAR", "INTERSTITIAL", "REWARDED"
  code        String   // HTML scripts / Google AdSense tag
  isActive    Boolean  @default(true)
}

model GameView {
  id        String   @id @default(uuid())
  gameId    String
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  viewedAt  DateTime @default(now())
}

model LivePlayer {
  id        String   @id @default(uuid())
  userId    String
  gameId    String?
  lastSeen  DateTime @default(now())
}

model Transaction {
  id        String   @id @default(uuid())
  amount    Float
  coins     Int
  userId    String
  status    String   // "SUCCESS", "PENDING", "FAILED"
  createdAt DateTime @default(now())
}

model GamePlay {
  id        String   @id @default(uuid())
  gameId    String
  userId    String
  score     Int      @default(0)
  duration  Int      @default(0) // seconds played
  createdAt DateTime @default(now())
}

model TrafficLog {
  id        String   @id @default(uuid())
  country   String   @default("US")
  device    String   @default("Desktop")
  browser   String   @default("Chrome")
  referrer  String   @default("Organic")
  path      String   @default("/")
  createdAt DateTime @default(now())
}

model ChatMessage {
  id        String   @id @default(uuid())
  room      String   @default("global") // "global" or game slug
  username  String
  avatarUrl String
  content   String
  isVip     Boolean  @default(false)
  createdAt DateTime @default(now())
}

model DailyRewardClaim {
  id        String   @id @default(uuid())
  userId    String
  rewardType String
  amount    Int
  createdAt DateTime @default(now())
}
